{
  "$schema": "https://orqastudio.dev/schemas/platform-config.json",
  "description": "Core platform configuration — artifact types, relationships, and validation constraints. Both the CLI validator and the Rust validator evaluate these schemas generically.",

  "artifactTypes": [
    { "key": "vision", "label": "Vision", "icon": "eye", "idPrefix": "VISION" },
    { "key": "pillar", "label": "Pillar", "icon": "columns-3", "idPrefix": "PILLAR" },
    { "key": "persona", "label": "Persona", "icon": "users", "idPrefix": "PERSONA" },
    { "key": "idea", "label": "Idea", "icon": "lightbulb", "idPrefix": "IDEA" },
    { "key": "decision", "label": "Decision", "icon": "scale", "idPrefix": "AD" },
    { "key": "rule", "label": "Rule", "icon": "shield", "idPrefix": "RULE" },
    { "key": "lesson", "label": "Lesson", "icon": "book-open", "idPrefix": "IMPL" },
    { "key": "knowledge", "label": "Knowledge", "icon": "zap", "idPrefix": "KNOW" },
    { "key": "agent", "label": "Agent", "icon": "bot", "idPrefix": "AGENT" },
    { "key": "doc", "label": "Document", "icon": "file-text", "idPrefix": "DOC" },
    { "key": "pivot", "label": "Pivot", "icon": "refresh-cw", "idPrefix": "PIVOT" }
  ],

  "relationships": [
    {
      "key": "upholds",
      "inverse": "upheld-by",
      "label": "Upholds",
      "inverseLabel": "Upheld By",
      "from": ["pillar"],
      "to": ["vision"],
      "description": "Pillar supports the vision",
      "semantic": "foundation",
      "constraints": {
        "required": true,
        "minCount": 1
      }
    },
    {
      "key": "grounded",
      "inverse": "grounded-by",
      "label": "Grounded",
      "inverseLabel": "Grounded By",
      "from": ["idea"],
      "to": ["pillar"],
      "description": "Idea anchored to a foundational principle",
      "semantic": "foundation",
      "constraints": {
        "required": true,
        "minCount": 1
      }
    },
    {
      "key": "benefits",
      "inverse": "benefited-by",
      "label": "Benefits",
      "inverseLabel": "Benefited By",
      "from": ["idea"],
      "to": ["persona"],
      "description": "Idea serves a target persona",
      "semantic": "foundation",
      "constraints": {
        "required": true,
        "minCount": 1
      }
    },
    {
      "key": "crystallises",
      "inverse": "crystallised-by",
      "label": "Crystallises",
      "inverseLabel": "Crystallised By",
      "from": ["idea"],
      "to": ["decision"],
      "description": "Idea crystallises into an architecture decision",
      "semantic": "lineage"
    },
    {
      "key": "spawns",
      "inverse": "spawned-by",
      "label": "Spawns",
      "inverseLabel": "Spawned By",
      "from": ["idea"],
      "to": ["research"],
      "description": "Idea spawns an investigation",
      "semantic": "lineage"
    },
    {
      "key": "drives",
      "inverse": "driven-by",
      "label": "Drives",
      "inverseLabel": "Driven By",
      "from": ["decision"],
      "to": ["epic"],
      "description": "Decision motivates a body of delivery work",
      "semantic": "governance"
    },
    {
      "key": "governs",
      "inverse": "governed-by",
      "label": "Governs",
      "inverseLabel": "Governed By",
      "from": ["decision"],
      "to": ["rule"],
      "description": "Decision establishes governance — leads into the learning loop",
      "semantic": "governance"
    },
    {
      "key": "enforces",
      "inverse": "enforced-by",
      "label": "Enforces",
      "inverseLabel": "Enforced By",
      "from": ["rule"],
      "to": ["decision"],
      "description": "Rule enforces a decision",
      "semantic": "governance",
      "constraints": {
        "required": true,
        "minCount": 1
      }
    },
    {
      "key": "codifies",
      "inverse": "codified-by",
      "label": "Codifies",
      "inverseLabel": "Codified By",
      "from": ["rule"],
      "to": ["lesson"],
      "description": "Rule codifies a lesson into enforceable governance",
      "semantic": "governance"
    },
    {
      "key": "informs",
      "inverse": "informed-by",
      "label": "Informs",
      "inverseLabel": "Informed By",
      "from": ["research"],
      "to": ["decision"],
      "description": "Research findings inform an architecture decision",
      "semantic": "knowledge-flow"
    },
    {
      "key": "teaches",
      "inverse": "taught-by",
      "label": "Teaches",
      "inverseLabel": "Taught By",
      "from": ["lesson"],
      "to": ["decision"],
      "description": "Lesson teaches a future decision",
      "semantic": "knowledge-flow"
    },
    {
      "key": "guides",
      "inverse": "guided-by",
      "label": "Guides",
      "inverseLabel": "Guided By",
      "from": ["research"],
      "to": ["epic"],
      "description": "Research guides a body of delivery work",
      "semantic": "knowledge-flow"
    },
    {
      "key": "cautions",
      "inverse": "cautioned-by",
      "label": "Cautions",
      "inverseLabel": "Cautioned By",
      "from": ["lesson"],
      "to": ["epic"],
      "description": "Lesson cautions a body of delivery work",
      "semantic": "knowledge-flow"
    },
    {
      "key": "serves",
      "inverse": "served-by",
      "label": "Serves",
      "inverseLabel": "Served By",
      "from": ["agent"],
      "to": ["pillar", "persona"],
      "description": "Agent is accountable to a foundational principle",
      "semantic": "foundation",
      "constraints": {
        "required": true,
        "minCount": 1
      }
    },
    {
      "key": "employs",
      "inverse": "employed-by",
      "label": "Employs",
      "inverseLabel": "Employed By",
      "from": ["agent"],
      "to": ["knowledge"],
      "description": "Agent employs a knowledge capability",
      "semantic": "agency",
      "constraints": {
        "required": true,
        "minCount": 1
      }
    },
    {
      "key": "documents",
      "inverse": "documented-by",
      "label": "Documents",
      "inverseLabel": "Documented By",
      "from": ["doc"],
      "to": ["epic", "decision", "rule", "milestone"],
      "description": "Document describes an artifact for human reference",
      "semantic": "knowledge-flow"
    },
    {
      "key": "synchronised-with",
      "inverse": "synchronised-with",
      "label": "Synchronised With",
      "inverseLabel": "Synchronised With",
      "from": ["knowledge", "doc"],
      "to": ["knowledge", "doc"],
      "description": "Paired content kept in sync — agent-facing and human-facing versions",
      "semantic": "synchronisation",
      "constraints": {
        "requiredWhenSourceType": "knowledge",
        "minCount": 1,
        "description": "Every knowledge artifact must have at least one synchronised-with relationship to a human-facing doc (AD-058)"
      }
    },
    {
      "key": "merged-into",
      "inverse": "merged-from",
      "label": "Merged Into",
      "inverseLabel": "Merged From",
      "from": ["idea", "research"],
      "to": ["idea", "research"],
      "description": "Artifacts consolidated — multiple ideas or research threads become one",
      "semantic": "lineage"
    },
    {
      "key": "revises",
      "inverse": "revised-by",
      "label": "Revises",
      "inverseLabel": "Revised By",
      "from": ["pivot"],
      "to": ["vision", "persona", "pillar"],
      "description": "Pivot revises a foundational artifact",
      "semantic": "foundation",
      "constraints": {
        "required": true,
        "minCount": 1
      }
    }
  ],

  "semantics": {
    "foundation": {
      "description": "Relationships anchoring the foundational layer — vision, pillars, personas, agents, and changes to them",
      "keys": ["upholds", "upheld-by", "grounded", "grounded-by", "benefits", "benefited-by", "revises", "revised-by", "serves", "served-by"]
    },
    "lineage": {
      "description": "Relationships establishing artifact succession — one thing becoming or spawning another",
      "keys": ["crystallises", "crystallised-by", "spawns", "spawned-by", "merged-into", "merged-from"]
    },
    "governance": {
      "description": "Relationships where decisions and rules direct behaviour",
      "keys": ["drives", "driven-by", "governs", "governed-by", "enforces", "enforced-by", "codifies", "codified-by"]
    },
    "knowledge-flow": {
      "description": "Relationships where knowledge flows between artifacts",
      "keys": ["informs", "informed-by", "teaches", "taught-by", "guides", "guided-by", "cautions", "cautioned-by", "documents", "documented-by"]
    },
    "agency": {
      "description": "Relationships where agents consume knowledge capabilities",
      "keys": ["employs", "employed-by"]
    },
    "synchronisation": {
      "description": "Paired content kept in sync",
      "keys": ["synchronised-with"]
    }
  }
}
